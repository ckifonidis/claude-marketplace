// FILE: src/tools/{{TOOL_NAME}}/actions/{{ACTION_NAME}}/executor.ts
//
// Paginated read executor (library `pageable`). Use for an action that returns
// a LARGE or unbounded list (search, browse, history). You do NOT page by hand:
// declare `pageable` on the action (config, below) and the runner does the rest —
// it injects `page`/`pageSize` params, slices your result, and emits a uniform
// envelope { page, pageSize, totalCount, totalPages, hasMore, items, fromCache }.
// In SELF mode it also caches the full set in the library-managed `pagedRead`
// slot, so a same-query re-page skips this executor entirely.
//
// Two modes (set on the action's `pageable`):
//   - SELF (`pageable: true`)        — return the FULL set in `resultBody.items`;
//     the runner slices + caches it. Use when the backend returns everything.
//   - DELEGATE (`pageable: "delegate"`) — the backend pages; read the injected
//     `page`/`pageSize` from params, return that page in `resultBody.items` plus
//     `resultBody.totalCount`. The runner wraps it (no cache).
//
// This template shows SELF mode (the common case). DELEGATE variant at the bottom.

import { postBackend } from "../../backend/client.js";
import { {{TOOL_NAME}}Env } from "../../backend/env.js";
import type { State } from "../../../../state.js";
import type { ExecutorResult } from "../../../../agent-step/index.js";
import type { Slice } from "./stateSelector.js";

interface Params {
  // {{FILTER_FIELDS}} — the fields that DEFINE the result set (a query, a date
  //                     range, an entity ref). The runner also injects optional
  //                     `page` / `pageSize`; in SELF mode you don't read them —
  //                     the runner handles paging + the cache.
}

interface Row {
  // {{ROW_FIELDS}} — one item the model sees per page. Keep it to what the model
  //                  needs to speak.
}

export async function {{EXECUTOR_FN_NAME}}(
  rawParams: unknown,
  state: Slice,
): Promise<ExecutorResult<State>> {
  const p = rawParams as Params;

  // Fetch the FULL set. The runner slices it into the requested page and caches
  // the whole set under this query's signature (so re-paging is free).
  const resp = await postBackend<{ payload?: { items?: Row[] } }>(
    {{TOOL_NAME}}Env.{{BASE_URL_FIELD}},
    "{{BACKEND_ENDPOINT}}",
    {
      // {{BACKEND_REQUEST_FIELDS}} — send the filter; fetch the whole set, not a page.
    },
    { envelope: "{{ENVELOPE_MODE}}" }, // "full" or "payload-only"
  );
  const rows: Row[] = resp?.payload?.items ?? [];
  // (Optional) sort into a STABLE order so page boundaries are deterministic:
  // rows.sort((a, b) => /* … */);

  // Return the FULL set in `items`. The runner REPLACES `items` with the page
  // and adds { page, pageSize, totalCount, totalPages, hasMore, fromCache }.
  // Any OTHER fields you return (summary, domain headlines) are preserved on
  // every page, including cache hits. Do NOT slice or count here.
  return {
    resultBody: {
      summary: `{{HUMAN_READABLE_SUMMARY}}`,
      items: rows,
    },
    ok: true,
  };
}

// ─── config.ts ──────────────────────────────────────────────────────────────
//   Declare this action `pageable` with a z.object params schema (the runner
//   merges page/pageSize in — a non-object schema throws at construction):
//
//     {{ACTION_NAME}}: {
//       description: "… Returns one page; re-call with page:n+1 for more.",
//       paramsSchema: z.object({ /* {{FILTER_FIELDS}} */ }),
//       prereqs: [...],
//       pageable: true,            // SELF: executor returns the full set
//       // pageable: "delegate",   // DELEGATE: backend pages (variant below)
//       // pageable: { mode: true, pageSize: 20, maxPageSize: 100 },  // tune sizes
//     },
//
// ─── state.ts ───────────────────────────────────────────────────────────────
//   The `pagedRead` slot is library-managed and ships in the bootstrap state
//   template (alongside awaitingInput / currentFlow) — no per-tool slot needed.
//
// ─── prompt ─────────────────────────────────────────────────────────────────
//   Teach the model: results are paged; the body carries { page, totalPages,
//   hasMore, totalCount }. To see more, re-call the SAME action with `page: n+1`
//   and the SAME filters — it re-pages from the cache for free.
//
// ─── DELEGATE variant (backend already pages) ─────────────────────────────────
