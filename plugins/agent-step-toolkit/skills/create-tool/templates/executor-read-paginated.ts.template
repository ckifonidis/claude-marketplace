//   const resp = await postBackend(..., { /* filters */ page, pageSize });
//   return { resultBody: { summary, items: resp.payload.items ?? [],
//                          totalCount: resp.payload.total ?? 0 }, ok: true };
//   // config: pageable: "delegate"
