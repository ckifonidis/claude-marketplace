{
  "name": "{{PROJECT_NAME}}",
  "version": "0.1.0",
  "description": "{{ONE_LINE_DESCRIPTION}}",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test dist/agent-step/*.test.js",
    "test:sandbox": "tsc && sh -c 'F=$(find dist/tools -path \"*/tests/tool/*.test.js\" 2>/dev/null); [ -n \"$F\" ] && node --test $F || echo \"no sandbox tests yet\"'",
    "test:prompt": "tsc && sh -c 'F=$(find dist/tools -path \"*/tests/prompt-input/*.test.js\" 2>/dev/null); [ -n \"$F\" ] && PROMPT_INPUT_LIVE=1 node --test $F || echo \"no prompt-input tests yet\"'",
    "test:all": "npm run test && npm run test:sandbox",
    "dev": "npx @langchain/langgraph-cli dev",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.8",
    "@langchain/openai": "^1.4.4",
    "dotenv": "^16.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.1.17",
    "@types/node": "^22.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0"
  }
}
