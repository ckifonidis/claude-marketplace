# Azure OpenAI — required for the LLM call
AZURE_OPENAI_ENDPOINT=https://YOUR-INSTANCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
TEMPERATURE=0

# Backend(s) the new tool calls — add or rename per tool. Examples below.
# CUSTOMER_API_BASE_URL=
# ACCOUNTS_API_BASE_URL=

# Tenancy / envelope (backends that require a tenant/bank envelope)
SANDBOX_ID=default
APPLICATION_ID=
BANK=
CHANNEL=intranet
USER_ID=
BRANCH_CODE=
WORKSTATION=

# Channel handoff (role-dependent — delete the block that doesn't apply;
# wired by /create-tool step 6c, values captured at bootstrap)
# ORCHESTRATOR (scaffold tool action; read at call time):
# HANDOFF_ENABLED=true
# HANDOFF_TOOLS=
# SPECIALIZED (library opt-in via buildAgentStepTool({ handoff })):
# HANDOFF_OFF_TOPIC_MODE=terminate
# HANDOFF_TERMINATE_MESSAGE=
# HANDOFF_DELEGATE_URL=
# HANDOFF_DELEGATE_ASSISTANT_ID=
# HANDOFF_DELEGATE_REPLY_NODE=

# LangSmith tracing (optional)
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT={{PROJECT_NAME}}

# LangGraph dev server (optional persistence)
DATABASE_URI=
REDIS_URI=

# Testing
# Sandbox tests (npm run test:sandbox) hit the local sandbox at each tool's
# *_BASE_URL above — start the sandbox before running them. Prompt-input tests
# (npm run test:prompt) call the live model and cost money; the script sets
# PROMPT_INPUT_LIVE=1 for you. Set it yourself only to run a single compiled
# prompt-input test file directly via `node --test`.
# PROMPT_INPUT_LIVE=1
