// FILE: src/tools/{{TOOL_NAME}}/shared/reslice-cache.ts
//
// Helper for the reslice-cache used by paginated read actions. A paginated read
// fetches the FULL set once, stores it (+ this signature) in a state slot, and
// serves pages from it. A later call with the SAME signature re-pages from
// state instead of re-hitting the backend; a DIFFERENT signature refetches.

/** Deterministic signature of a query's result set. Pass the normalized parts
 *  that DEFINE the set — every filter / query / date-range / id-list field —
 *  but NOT page or pageSize (paging within one set must reuse the cache).
 *
 *  - Array-valued parts are sorted, so they're order-independent
 *    (`["b","a"]` ⇒ same signature as `["a","b"]`).
 *  - Scalar parts are positional (a `{from,to}` range keeps its order).
 *  - null / undefined collapse to empty — pass fields in a STABLE argument
 *    order so an omitted optional doesn't shift the others.
 *
 *  Example:
 *    querySignature(ids, query, dateFrom, dateTo)
 */
export function querySignature(
  ...parts: Array<string | number | boolean | string[] | null | undefined>
): string {
  return parts
    .map((part) => {
      if (part == null) return "";
      if (Array.isArray(part)) return [...part].map(String).sort().join(",");
      return String(part);
    })
    .join("|");
}
